# Skopiuj ten plik jako .env i uzupełnij wartości. Plik .env NIE trafia do
# repozytorium (patrz .gitignore) — nigdy nie commituj prawdziwych sekretów.

# --- Supabase (wymagane) ---
# Znajdziesz w Supabase Studio: Project Settings -> API.
# VITE_SUPABASE_ANON_KEY to publiczny klucz "anon" — bezpieczny do użycia w
# przeglądarce, dostęp do danych chroni Row Level Security. NIGDY nie używaj
# tu klucza "service_role".
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Import z Google Maps (opcjonalne) ---
# Ustaw na "false", żeby całkowicie ukryć funkcję importu z Google Maps
# (np. jeśli nie chcesz płacić za Google Places API). Ręczne dodawanie
# leadów działa niezależnie od tego ustawienia.
VITE_ENABLE_GOOGLE_IMPORT=true

# Uwaga: klucz GOOGLE_PLACES_API_KEY NIE jest zmienną VITE_* i NIE należy do
# tego pliku — to sekret dla Cloudflare Pages Function (functions/api/places/lookup.ts).
# Do lokalnego testowania (wrangler pages dev) wpisz go w pliku .dev.vars
# (skopiuj .dev.vars.example). Do produkcji dodaj go jako sekret w panelu
# Cloudflare Pages. Instrukcja: README, sekcja "Konfiguracja Google Places".
